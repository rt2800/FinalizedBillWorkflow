{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.example.com/schemas/order.schema.json",
  "title": "Order",
  "description": "Schema for an order payload — mirrors the OpenAPI components/schemas/Order definition",
  "type": "object",
  "required": ["orderId", "customerId", "items", "totalAmount", "currency"],
  "additionalProperties": false,
  "properties": {
    "orderId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the order (UUID v4)"
    },
    "customerId": {
      "type": "string",
      "minLength": 3,
      "maxLength": 50,
      "pattern": "^[A-Za-z0-9_-]+$",
      "description": "Identifier of the customer placing the order"
    },
    "orderDate": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of when the order was placed"
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "description": "Line items in the order",
      "items": {
        "type": "object",
        "required": ["productId", "quantity", "unitPrice"],
        "additionalProperties": false,
        "properties": {
          "productId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "productName": {
            "type": "string",
            "maxLength": 255
          },
          "quantity": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10000
          },
          "unitPrice": {
            "type": "number",
            "exclusiveMinimum": 0,
            "multipleOf": 0.01
          },
          "discount": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "Discount percentage (0–100)"
          }
        }
      }
    },
    "totalAmount": {
      "type": "number",
      "minimum": 0,
      "multipleOf": 0.01,
      "description": "Total order value after discounts"
    },
    "currency": {
      "type": "string",
      "enum": ["USD", "EUR", "GBP", "JPY", "CAD", "AUD"],
      "description": "ISO 4217 currency code"
    },
    "shippingAddress": {
      "type": "object",
      "required": ["street", "city", "country"],
      "additionalProperties": false,
      "properties": {
        "street":  { "type": "string", "maxLength": 255 },
        "city":    { "type": "string", "maxLength": 100 },
        "state":   { "type": "string", "maxLength": 100 },
        "zip":     { "type": "string", "pattern": "^[A-Z0-9 -]{3,10}$" },
        "country": { "type": "string", "minLength": 2, "maxLength": 2, "description": "ISO 3166-1 alpha-2 country code" }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Arbitrary string key-value pairs for extensibility"
    }
  }
}
