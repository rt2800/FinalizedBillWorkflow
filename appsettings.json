{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "RabbitMQ.Client": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "OracleDbConnection": "Data Source=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCPS)(HOST=oracle-server)(PORT=2484))(CONNECT_DATA=(SERVICE_NAME=pdb1)));User Id=myuser;Password=mypassword;"
  },

  // ── RabbitMQ connection settings ──────────────────────────────────────────
  "RabbitMQ": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "ExchangeName": "",
    "DeadLetterExchange": "dlx"
  },

  // ── Schema registry — each entry maps a name to a schema file ─────────────
  // Add as many schemas as you need; the file paths are relative to the
  // application content root (i.e. the project folder during development).
  "SchemaRegistry": [
    {
      "Name": "order",
      "FilePath": "Schemas/order.schema.json",
      "Description": "E-commerce order payload",
      "Version": "1.0.0"
    }
  ],

  // ── Serilog (overrides the default Logging section) ────────────────────────
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "RabbitMQ.Client": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} | {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}
